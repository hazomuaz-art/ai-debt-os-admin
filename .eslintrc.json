{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "@next/next/no-img-element": "error",
    "react-hooks/exhaustive-deps": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "tests/",
    "scripts/"
  ]
}
