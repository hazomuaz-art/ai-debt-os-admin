# ============================================================
# AI Debt OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI (required) ────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── Application Security (required) ─────────────────────────
# Generate: openssl rand -base64 32
APP_SECRET=your-random-secret-minimum-32-characters-here

# Your deployed application URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── WhatsApp Cloud API (optional) ───────────────────────────
# Get from: Meta Developer Dashboard → Your App → WhatsApp → API Setup
# Leave blank to disable WhatsApp messaging features.
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=any-random-string-you-choose
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# ── Vercel Cron (auto-set by Vercel in production) ──────────
# Do NOT set this manually — Vercel injects it automatically.
# CRON_SECRET=auto-set-by-vercel
